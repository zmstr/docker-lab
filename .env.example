# =============================================================================
# Environment Variables — Home Lab Stack
# =============================================================================
# Copy this file to .env and fill in ALL values before starting the stack:
#   cp .env.example .env
#   nano .env
#
# NEVER commit .env to version control. It is listed in .gitignore.
# =============================================================================

# -----------------------------------------------------------------------------
# General
# -----------------------------------------------------------------------------
# Your local timezone (used by Home Assistant and other containers).
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Europe/Brussels

# -----------------------------------------------------------------------------
# WireGuard Easy
# -----------------------------------------------------------------------------
# Public IP address or hostname of this NUC as seen from the internet.
# Used inside the WireGuard client configuration files that wg-easy generates.
# If you have a dynamic IP, set up a DDNS service (e.g., DuckDNS) and put the
# hostname here.
WG_HOST=YOUR_PUBLIC_IP_OR_DDNS_HOSTNAME

# bcrypt password hash for the wg-easy web UI.
# Generate with:
#   docker run --rm -it ghcr.io/wg-easy/wg-easy wgpw YOUR_PASSWORD
# Copy the entire output line starting with $2b$...
WG_PASSWORD_HASH=

# -----------------------------------------------------------------------------
# Vaultwarden
# -----------------------------------------------------------------------------
# Admin panel token — used to access /admin on your Vaultwarden instance.
# Generate a secure random token with:
#   openssl rand -base64 48
# Keep this secret. Anyone with this token has full admin access.
VAULTWARDEN_ADMIN_TOKEN=
